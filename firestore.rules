// Reglas de seguridad de Firestore.
// Pegar esto en: Firebase Console > Firestore Database > Reglas (Rules)
//
// Esta app no usa Firebase Authentication (el login es propio, con usuario/clave
// guardados en la colección "users"), así que las reglas permiten lectura y escritura
// general. Esto es razonable para el uso previsto (grupo cerrado de una comisión,
// sin datos sensibles de terceros), pero cualquiera con la URL del proyecto de Firebase
// podría en teoría leer/escribir los datos si conociera el projectId.
//
// Si más adelante se quiere mayor seguridad, se puede migrar a Firebase Authentication
// real (login con email/contraseña) y restringir estas reglas a "request.auth != null".

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
